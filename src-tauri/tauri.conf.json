{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xBark",
  "version": "0.1.3",
  "identifier": "sh.w-mai.xbark",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/**", "$HOME/**", "$RESOURCE/**", "**"],
          "deny": []
        }
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
